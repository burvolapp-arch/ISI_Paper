{
  // ===========================================================================
  // VS Code settings for ISI_Paper — LaTeX Workshop
  // ===========================================================================
  // Extension: James-Yu.latex-workshop
  // ===========================================================================

  // --- Build Recipe (latexmk + xelatex) -------------------------------------
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (xelatex)",
      "tools": ["latexmk-xelatex"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-xelatex",
      "command": "latexmk",
      "args": [
        "-xelatex",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-halt-on-error",
        "-file-line-error",
        "-outdir=output",
        "%DOC%"
      ],
      "env": {}
    }
  ],

  // --- Output Directory ------------------------------------------------------
  "latex-workshop.latex.outDir": "output",

  // --- Auto-build on save ----------------------------------------------------
  "latex-workshop.latex.autoBuild.run": "onSave",

  // --- Clean auxiliary files on demand ---------------------------------------
  "latex-workshop.latex.clean.fileTypes": [
    "output/*.aux",
    "output/*.bbl",
    "output/*.bcf",
    "output/*.blg",
    "output/*.fdb_latexmk",
    "output/*.fls",
    "output/*.log",
    "output/*.out",
    "output/*.toc",
    "output/*.lof",
    "output/*.lot",
    "output/*.synctex.gz",
    "output/*.run.xml",
    "output/*.xdv"
  ],

  // --- SyncTeX / Forward+Inverse Search (Skim) ------------------------------
  "latex-workshop.view.pdf.viewer": "external",
  "latex-workshop.view.pdf.external.synctex.command": "/Applications/Skim.app/Contents/SharedSupport/displayline",
  "latex-workshop.view.pdf.external.synctex.args": [
    "-r",
    "%LINE%",
    "%PDF%",
    "%TEX%"
  ],
  "latex-workshop.view.pdf.external.viewer.command": "/Applications/Skim.app/Contents/SharedSupport/displayline",
  "latex-workshop.view.pdf.external.viewer.args": [
    "0",
    "%PDF%"
  ],

  // --- Intellisense ----------------------------------------------------------
  "latex-workshop.intellisense.package.enabled": true,

  // --- Linting (chktex) — optional -------------------------------------------
  "latex-workshop.linting.chktex.enabled": true,
  "latex-workshop.linting.chktex.exec.path": "chktex",

  // --- Editor defaults for .tex files ----------------------------------------
  "[latex]": {
    "editor.wordWrap": "on",
    "editor.formatOnSave": false,
    "editor.suggestSelection": "recentlyUsed",
    "editor.tabSize": 2
  },
  "[bibtex]": {
    "editor.tabSize": 2
  },

  // --- Files -----------------------------------------------------------------
  "files.associations": {
    "*.tex": "latex",
    "*.bib": "bibtex",
    "*.cls": "latex",
    "*.sty": "latex"
  },
  "files.exclude": {
    "output/*.aux": true,
    "output/*.log": true,
    "output/*.fls": true,
    "output/*.fdb_latexmk": true,
    "output/*.synctex.gz": true,
    "output/*.xdv": true
  }
}
